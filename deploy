#!/bin/bash
set -o nounset
set -o errexit
set -o xtrace

CIRCLE_PROJECT_USERNAME=${CIRCLE_PROJECT_USERNAME:-""}
CIRCLE_PR_NUMBER=${CIRCLE_PR_NUMBER:-""}

if [ "$#" -lt 1 ]; then
	echo -e "Usage:\n$0 <host_alias>"
	exit 1;
fi

EXPLORER=${EXPLORER:-"../data-explorer/out"}

if [ ! -e "${EXPLORER}/references/index.html" ]; then
	echo "Error: ${EXPLORER}/references/index.html not found"
	exit 1;
fi

HOST_ALIAS="$1"

case "$HOST_ALIAS" in
	bedev) ;;
	beprod) ;;
	*) echo -e "Unknown host alias $HOST_ALIAS"; exit 1;;
esac

HOST=$(ssh -G "$HOST_ALIAS" | grep -oP '(?<=^hostname ).*')

#if [ "$CIRCLE_PROJECT_USERNAME" != 'ucscBrainExplorer' ] || [ ! -z $CIRCLE_PR_NUMBER ]; then
#	exit;
#fi

USER=ubuntu
BUILD_DJANGO=build-django
RSYNC_OPTS=(-a --delete --exclude='.*.sw[opx]' -e "ssh -o StrictHostKeyChecking=no")

npm run build:prod -- --bail
rsync -a "${EXPLORER}/" build

# deploy
rsync "${RSYNC_OPTS[@]}" --rsync-path='sudo rsync' build/ ${USER}@${HOST}:/var/www/html
# copy to clean load directory, so we can rsync --delete
rm -rf ${BUILD_DJANGO}
mkdir ${BUILD_DJANGO}
# copy only the python files that are in git, to avoid temporary files.
git ls-files -z requirements.txt manage.py server jobs templates static | rsync -a --files-from=- --from0 ./ "$BUILD_DJANGO"/
# include the Brain Explorer metadata JSON from the data-explorer repo
cp "${EXPLORER}/../UCSC_Brain_Explorer_metadata.json" "$BUILD_DJANGO"/
rsync "${RSYNC_OPTS[@]}" ${BUILD_DJANGO}/ ${USER}@${HOST}:/var/www/backend/django

ssh -l${USER} ${HOST} <<-ENDSSH
    #set -o nounset # 'activate' accesses unbound vars
    set -o errexit
    set -o xtrace
    cp ~/settings/site_settings.py /var/www/backend/django/server/site_settings.py
    cp ~/settings/config.js /var/www/html/config.js
    . /var/www/backend/virtualenv/bin/activate
    cd /var/www/backend/django
    # Stop rqworker before touching code. It runs jobs for 40+ minutes and
    # can hold old code in memory, causing ORM errors if it picks up a new
    # job mid-deploy. Jobs in the Redis queue simply wait and are picked up
    # by the new worker after start.
    sudo systemctl stop rqworker
    pip install --no-cache-dir --require-hashes -r requirements.txt
    # Remove stale .pyc bytecode so Python recompiles fresh on next startup.
    # pip skips packages already at the correct version, leaving old .pyc files
    # in place, which can cause SQLCompiler/ORM errors.
    find /var/www/backend -name '*.pyc' -delete
    python ./manage.py migrate
    python manage.py collectstatic
    # Pre-download the sentence-transformers embedding model so Apache (www-data)
    # never needs to fetch it at request time. Keep files owned by ubuntu (so the
    # next deploy can overwrite them) but make them world-readable for www-data.
    mkdir -p /var/www/backend/st-models
    SENTENCE_TRANSFORMERS_HOME=/var/www/backend/st-models HF_HOME=/var/www/backend/st-models \
        python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"
    chmod -R a+rX /var/www/backend/st-models
    sudo apache2ctl restart
    sudo systemctl start rqworker
    python manage.py recover_pending_projections
ENDSSH
